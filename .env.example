# N-sight MCP Server — Environment Configuration
# Copy this file to .env and fill in your values

# Required: Your N-sight API key
# Generate at: Settings > General Settings > API in N-sight
NSIGHT_API_KEY=

# Required: Your N-sight regional server URL
# See: https://developer.n-able.com/n-sight/docs/determine-server-for-api-query
# Examples:
#   https://www.systemmonitor.us      (North America)
#   https://www.systemmonitor.eu      (Europe)
#   https://wwwasia.systemmonitor.us  (Asia Pacific)
NSIGHT_SERVER_URL=

# Optional: Restrict all API calls to a specific client group
# Recommended for Production server — leave blank for all clients
NSIGHT_CLIENT_ID=

# Optional: Override the default rate limit (max 60 — do not exceed)
NSIGHT_RATE_LIMIT_PER_MIN=60

# Production server only: Maximum write actions per session
NSIGHT_MAX_WRITES_PER_SESSION=20

# Production server only: Set to "true" to enable audit logging
NSIGHT_AUDIT_LOG_ENABLED=true

# Production server only: Path for audit log file
NSIGHT_AUDIT_LOG_PATH=./logs/audit.log
